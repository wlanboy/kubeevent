{
  "title": "PVC Events",
  "uid": "kube-pvc-events",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Datasource"
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": "$datasource",
        "label": "Namespace",
        "query": "label_values(kubeevents_pvc_total, namespace)"
      },
      {
        "name": "pvc",
        "type": "query",
        "datasource": "$datasource",
        "label": "PVC",
        "query": "label_values(kubeevents_pvc_total{namespace=\"$namespace\"}, pvc)"
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Total Events for PVC",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 3 },
      "targets": [
        {
          "expr": "sum(kubeevents_pvc_total{namespace=\"$namespace\", pvc=\"$pvc\"})"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Warning Events",
      "datasource": "$datasource",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 3 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "expr": "sum(kubeevents_pvc_total{namespace=\"$namespace\", pvc=\"$pvc\", type=\"Warning\"})"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Events per Second",
      "datasource": "$datasource",
      "gridPos": { "x": 8, "y": 0, "w": 16, "h": 6 },
      "targets": [
        {
          "expr": "rate(kubeevents_pvc_total{namespace=\"$namespace\", pvc=\"$pvc\"}[5m])",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Events by Reason",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "rate(kubeevents_involved_total{namespace=\"$namespace\", kind=\"PersistentVolumeClaim\", involved_name=\"$pvc\"}[5m])",
          "legendFormat": "{{reason}} / {{type}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Events by Component",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "rate(kubeevents_involved_total{namespace=\"$namespace\", kind=\"PersistentVolumeClaim\", involved_name=\"$pvc\"}[5m])",
          "legendFormat": "{{component}} / {{reason}}"
        }
      ]
    },
    {
      "type": "table",
      "title": "All PVCs in Namespace (5m Increase)",
      "datasource": "$datasource",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 7 },
      "targets": [
        {
          "expr": "sort_desc(sum by (pvc, type) (increase(kubeevents_pvc_total{namespace=\"$namespace\"}[5m])))",
          "legendFormat": "{{pvc}} / {{type}}",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": {} },
        { "id": "organize", "options": { "renameByName": { "pvc": "PVC", "type": "Type", "Value": "Events (5m)" } } }
      ]
    }
  ]
}
